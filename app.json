{
    "name": "BugBotPro",
    "description": "WhatsApp tools web dashboard — no Telegram needed",
    "keywords": ["whatsapp", "dashboard", "nodejs"],
    "repository": "https://github.com/msarim21/bugbotpro",
    "env": {
      "JWT_SECRET": {
        "description": "Secret key for web panel JWT tokens",
        "generator": "secret"
      },
      "ADMIN_EMAIL": {
        "description": "Admin email for first login",
        "required": false
      },
      "ADMIN_PASSWORD": {
        "description": "Admin password for first login",
        "required": false
      },
      "APP_URL": {
        "description": "Your Heroku app URL for keepalive",
        "required": false
      },
      "NPM_CONFIG_PRODUCTION": {
        "description": "Must be false so devDependencies install for React build",
        "value": "false"
      }
    },
    "formation": {
      "web": {
        "quantity": 1,
        "size": "eco"
      }
    },
    "buildpacks": [{"url": "heroku/nodejs"}],
    "scripts": {"postdeploy": "echo BugBotPro deployed"},
    "stack": "heroku-24"
  }
  