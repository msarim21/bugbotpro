{
    "name": "BugBotPro",
    "description": "WhatsApp Web Dashboard — no Telegram needed",
    "keywords": ["whatsapp", "dashboard", "nodejs"],
    "repository": "https://github.com/msarim21/bugbotpro",
    "env": {
      "JWT_SECRET": {
        "description": "Auto-generated secret for JWT tokens",
        "generator": "secret"
      },
      "ADMIN_EMAIL": {
        "description": "Your admin email for first login (optional)",
        "required": false,
        "value": ""
      },
      "ADMIN_PASSWORD": {
        "description": "Your admin password (optional)",
        "required": false,
        "value": ""
      },
      "APP_URL": {
        "description": "Your Heroku app URL e.g. https://my-app.herokuapp.com (optional)",
        "required": false,
        "value": ""
      },
      "NPM_CONFIG_PRODUCTION": {
        "description": "Must be false so React client builds correctly",
        "value": "false"
      }
    },
    "formation": {
      "web": {
        "quantity": 1,
        "size": "eco"
      }
    },
    "buildpacks": [
      {
        "url": "heroku/nodejs"
      }
    ],
    "stack": "heroku-24"
  }
  