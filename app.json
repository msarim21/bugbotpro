{
    "name": "BugBotPro",
    "description": "WhatsApp Web Dashboard — no Telegram needed",
    "keywords": ["whatsapp", "dashboard", "nodejs"],
    "repository": "https://github.com/msarim21/bugbotpro",
    "env": {
      "JWT_SECRET": {
        "description": "Secret key for login sessions (auto-generated)",
        "generator": "secret"
      },
      "NPM_CONFIG_PRODUCTION": {
        "description": "Set false so React frontend builds on Heroku",
        "value": "false"
      },
      "ADMIN_EMAIL": {
        "description": "Admin login email — pehla signup account (optional)",
        "required": false
      },
      "ADMIN_PASSWORD": {
        "description": "Admin login password (optional)",
        "required": false
      }
    },
    "formation": {
      "web": {
        "quantity": 1,
        "size": "eco"
      }
    },
    "buildpacks": [
      {
        "url": "heroku/nodejs"
      }
    ],
    "stack": "heroku-24"
  }
  